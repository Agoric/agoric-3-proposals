{
  "name": "@agoric/synthetic-chain",
  "version": "0.7.0",
  "description": "Utilities to build a chain and test proposals atop it",
  "bin": "dist/cli/cli.mjs",
  "main": "./dist/lib/index.mjs",
  "type": "module",
  "module": "./dist/lib/index.mjs",
  "exports": "./dist/lib/index.mjs",
  "types": "./dist/lib/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "yarn build",
    "build": "tsdown",
    "test": "ava"
  },
  "engines": {
    "node": "^18.19 || ^20.9 || ^22.11"
  },
  "dependencies": {
    "@agoric/client-utils": "0.1.1-dev-c393dc4.0.c393dc4",
    "@endo/zip": "^1.0.11",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.6.2",
    "cosmjs-types": "^0.10.1",
    "execa": "^9.6.1",
    "glob": "^13.0.6",
    "tmp": "0.2.5"
  },
  "devDependencies": {
    "@agoric/cosmic-proto": "0.4.1-dev-c393dc4.0.c393dc4",
    "@agoric/fast-usdc": "0.1.1-dev-c393dc4.0.c393dc4",
    "@agoric/inter-protocol": "0.16.2-dev-c393dc4.0.c393dc4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.17",
    "@types/tmp": "0.2.6",
    "ava": "^7.0.0",
    "ts-blank-space": "^0.8.0",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2"
  },
  "ava": {
    "extensions": {
      "js": true,
      "ts": "module"
    },
    "environmentVariables": {
      "binary": "fake-agd",
      "ATOM_DENOM": "uatom",
      "CHAINID": "fakechain",
      "HOME": "/tmp/fake-home"
    },
    "nodeArguments": [
      "--import=ts-blank-space/register"
    ]
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  }
}
